<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tracking_turret">

  <!-- Properties -->
  <xacro:property name="base_height" value="0.1"/>
  <xacro:property name="base_radius" value="0.15"/>
  <xacro:property name="yaw_platform_height" value="0.05"/>
  <xacro:property name="yaw_platform_radius" value="0.12"/>
  <xacro:property name="pitch_arm_length" value="0.1"/>
  <xacro:property name="pitch_arm_width" value="0.04"/>
  <xacro:property name="sensor_head_size" value="0.08"/>

  <!-- Materials -->
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>

  <!-- Base Link (fixed to world) -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 ${base_height/2}"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- Yaw Joint (pan) -->
  <joint name="yaw_joint" type="revolute">
    <parent link="base_link"/>
    <child link="yaw_platform"/>
    <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-pi}" upper="${pi}" effort="10" velocity="2.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- Yaw Platform -->
  <link name="yaw_platform">
    <visual>
      <geometry>
        <cylinder radius="${yaw_platform_radius}" length="${yaw_platform_height}"/>
      </geometry>
      <origin xyz="0 0 ${yaw_platform_height/2}" rpy="0 0 0"/>
      <material name="light_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${yaw_platform_radius}" length="${yaw_platform_height}"/>
      </geometry>
      <origin xyz="0 0 ${yaw_platform_height/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 ${yaw_platform_height/2}"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Pitch Joint (tilt) -->
  <joint name="pitch_joint" type="revolute">
    <parent link="yaw_platform"/>
    <child link="pitch_arm"/>
    <origin xyz="0 0 ${yaw_platform_height}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi/3}" upper="${pi/3}" effort="10" velocity="2.0"/>
    <dynamics damping="0.3" friction="0.1"/>
  </joint>

  <!-- Pitch Arm -->
  <link name="pitch_arm">
    <visual>
      <geometry>
        <box size="${pitch_arm_length} ${pitch_arm_width} ${pitch_arm_width}"/>
      </geometry>
      <origin xyz="${pitch_arm_length/2} 0 0" rpy="0 0 0"/>
      <material name="light_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="${pitch_arm_length} ${pitch_arm_width} ${pitch_arm_width}"/>
      </geometry>
      <origin xyz="${pitch_arm_length/2} 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="${pitch_arm_length/2} 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Sensor Head (fixed to pitch arm) -->
  <joint name="sensor_head_joint" type="fixed">
    <parent link="pitch_arm"/>
    <child link="sensor_head"/>
    <origin xyz="${pitch_arm_length} 0 0" rpy="0 0 0"/>
  </joint>

  <link name="sensor_head">
    <visual>
      <geometry>
        <box size="${sensor_head_size} ${sensor_head_size} ${sensor_head_size}"/>
      </geometry>
      <origin xyz="${sensor_head_size/2} 0 0" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${sensor_head_size} ${sensor_head_size} ${sensor_head_size}"/>
      </geometry>
      <origin xyz="${sensor_head_size/2} 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="${sensor_head_size/2} 0 0"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <!-- Camera Link -->
  <joint name="camera_joint" type="fixed">
    <parent link="sensor_head"/>
    <child link="camera_link"/>
    <origin xyz="${sensor_head_size} 0 0" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.03"/>
      </geometry>
      <origin xyz="0.015 0 0" rpy="0 ${pi/2} 0"/>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Camera Optical Frame (Z forward, X right, Y down - standard camera convention) -->
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <link name="camera_optical_frame"/>

  <!-- Radar Link (simulated) -->
  <joint name="radar_joint" type="fixed">
    <parent link="sensor_head"/>
    <child link="radar_link"/>
    <origin xyz="${sensor_head_size} 0 ${sensor_head_size/4}" rpy="0 0 0"/>
  </joint>

  <link name="radar_link">
    <visual>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
      <origin xyz="0.01 0 0" rpy="0 0 0"/>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Gazebo plugins -->
  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>50</update_rate>
      <joint_name>yaw_joint</joint_name>
      <joint_name>pitch_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- Camera sensor -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/turret</namespace>
          <remapping>image_raw:=camera/image_raw</remapping>
          <remapping>camera_info:=camera/camera_info</remapping>
        </ros>
        <frame_name>camera_optical_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Joint controllers for Gazebo -->
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(find turret_description)/config/turret_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- Transmission for joints -->
  <transmission name="yaw_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="yaw_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="yaw_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="pitch_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="pitch_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="pitch_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

</robot>
